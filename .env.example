# --- Database ---
DB_USERNAME=referral
DB_PASSWORD=change-me-strong-password
DB_DATABASE=referral
DB_HOST=postgres
DB_PORT=5432
DB_SYNCHRONIZE=false

# --- Secrets (generate: openssl rand -base64 48 / openssl rand -hex 32) ---
JWT_SECRET=change-me-min-32-chars-random-string-xxxxxxxxxxxxxxxx
ENCRYPTION_KEY=change-me-64-hex-chars-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- App ---
PORT=3001
NODE_ENV=production

# --- TLS / reverse proxy ---
# Email used by Caddy to register with Let's Encrypt (cert-renewal
# notifications land here).
CADDY_ACME_EMAIL=ops@refledger.io

# --- Backups (see ops/backup/README.md) ---
# Restic repository URL. Examples:
#   Backblaze B2:  b2:<bucket-name>:<path>
#   Local (dev):   /tmp/refledger-restic-test
BACKUP_RESTIC_REPOSITORY=b2:refledger-backups:prod
# Encryption password for the restic repo. LOSING THIS = BACKUPS UNRECOVERABLE.
# Generate: openssl rand -base64 48 — also store in password manager.
BACKUP_RESTIC_PASSWORD=change-me-40-random-chars
# Backblaze B2 creds (leave blank for non-B2 backends).
BACKUP_B2_ACCOUNT_ID=
BACKUP_B2_ACCOUNT_KEY=
# healthchecks.io ping URLs — one per cron job. Blank disables the ping.
BACKUP_HEALTHCHECK_BACKUP_URL=
BACKUP_HEALTHCHECK_PRUNE_URL=
BACKUP_HEALTHCHECK_RESTORE_TEST_URL=
# Host directory for the staging dump file (must be writable by the cron user).
BACKUP_STAGE_DIR=/var/backup/refledger/stage
