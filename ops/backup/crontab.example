# Refledger backup cron — paste into /etc/cron.d/refledger or `crontab -e`.
# All times UTC. Adjust REPO_PATH to wherever the repo lives on the host.
#
# MAILTO empty: alerting is via healthchecks.io (see .env). If you prefer
# cron email on failure, set MAILTO to your address — cron mails stderr.

SHELL=/bin/bash
PATH=/usr/local/bin:/usr/bin:/bin
MAILTO=""

# Hourly full backup at minute :05 (avoids hitting exactly on the hour
# when Postgres autovacuum often kicks in).
5 * * * *    cd /opt/refledger && ./ops/backup/backup.sh

# Nightly schema-only dump at 03:00.
0 3 * * *    cd /opt/refledger && ./ops/backup/schema-dump.sh

# Weekly retention prune, Sundays 04:00.
0 4 * * 0    cd /opt/refledger && ./ops/backup/prune.sh

# Monthly restore verification, 1st of the month 05:00.
0 5 1 * *    cd /opt/refledger && ./ops/backup/restore-test.sh
